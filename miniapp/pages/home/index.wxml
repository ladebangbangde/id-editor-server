<view class="container">
  <view class="card">
    <view class="section-title">上传自拍照</view>
    <button bindtap="chooseImage">选择图片</button>
    <image wx:if="{{localImagePath}}" class="preview" src="{{localImagePath}}" mode="aspectFit"></image>
  </view>

  <view class="card">
    <view class="section-title">选择背景色</view>
    <radio-group bindchange="onBgChange">
      <label wx:for="{{bgOptions}}" wx:key="value" class="option">
        <radio value="{{item.value}}" checked="{{item.value === bgColor}}" />{{item.label}}
      </label>
    </radio-group>
  </view>

  <view class="card">
    <view class="section-title">选择尺寸</view>
    <picker range="{{sizeOptions}}" range-key="label" value="{{sizeIndex}}" bindchange="onSizeChange">
      <view class="picker">{{sizeOptions[sizeIndex].label}}</view>
    </picker>
  </view>

  <button class="primary-btn" bindtap="handleGenerate" loading="{{loading}}">生成预览</button>
</view>
