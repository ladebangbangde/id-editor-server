{
  "name": "ai-id-photo-backend",
  "version": "1.0.0",
  "description": "Commercial-ready first version backend for AI ID photo mini-program",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:init": "mysql -u$DB_USER -p$DB_PASSWORD -h$DB_HOST -P$DB_PORT $DB_NAME < sql/init.sql",
    "test": "node --test test/**/*.test.js",
    "cleanup:run": "node scripts/run-photo-cleanup.js",
    "cleanup:dry-run": "node scripts/run-photo-cleanup.js --dry-run",
    "cleanup:repair": "node scripts/repair-photo-tasks.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.3",
    "node-cron": "^3.0.3",
    "sequelize": "^6.37.3",
    "sharp": "^0.33.5",
    "uuid": "^10.0.0",
    "winston": "^3.13.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
