NODE_ENV=development
PORT=3000
API_PREFIX=/api
BASE_URL=http://localhost:3000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ai_id_photo
DB_USER=root
DB_PASSWORD=123456
DB_LOGGING=false
DB_DIALECT=mysql
DB_TIMEZONE=+08:00
# 可选：单一连接串（优先于 DB_HOST/DB_PORT/DB_NAME/DB_USER/DB_PASSWORD）
# DB_URL=mysql://root:123456@127.0.0.1:3306/ai_id_photo
# 可选：通过 JSON 字符串注入数据库配置（会覆盖前面的 DB_*）
# DB_CONFIG_JSON={"database":"ai_id_photo","username":"root","password":"123456","options":{"host":"127.0.0.1","port":3306,"dialect":"mysql","timezone":"+08:00","logging":false}}
# 可选：通过文件注入数据库配置（容器挂载后填写路径，例如 /app/config/db.config.json）
# DB_CONFIG_FILE=/app/config/db.config.json

JWT_SECRET=replace-with-long-secret
JWT_EXPIRES_IN=7d
ADMIN_JWT_EXPIRES_IN=2h

UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

MOCK_USER_OPENID=mock_openid_1001
MOCK_USER_NICKNAME=演示用户
